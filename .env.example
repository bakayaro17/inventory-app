# Copy this file to `.env` (gitignored) and fill in your values.
# These are baked into the build, so you never paste them in the app.
#
# Find URL + anon key in Supabase -> Project Settings -> API.
# The anon key is safe to ship: RLS blocks every table behind a logged-in user.

VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# The single account the password screen signs in as. With this set, the login
# page asks only for a password (iPhone-passcode style). Create this user in
# Supabase -> Authentication -> Users.
VITE_LOGIN_EMAIL=you@example.com
